{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "小柳语音转写",
  "version": "0.2.0",
  "identifier": "com.kimliu.voice2text",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "小柳语音转写",
        "width": 980,
        "height": 740,
        "minWidth": 760,
        "minHeight": 560,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/ffmpeg-bundle/", "resources/whisper-cli-bundle/"]
  }
}
